Options -Indexes

# Bloquear archivos sensibles
<FilesMatch "\.(sql|log|env|md|sh|bak)$">
    Require all denied
</FilesMatch>

# Página de inicio
DirectoryIndex index.php

# Rewrite solo si el módulo está disponible
<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

# Headers de seguridad solo si el módulo está disponible
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
</IfModule>

# Compresión solo si el módulo está disponible
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Cache para assets estáticos solo si el módulo está disponible
<IfModule mod_expires.c>
    ExpiresActive On
    <FilesMatch "\.(css|js|png|jpg|gif|ico|woff2)$">
        ExpiresDefault "access plus 7 days"
    </FilesMatch>
</IfModule>
